{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/AnthonyPuggs/ausecon-mcp-server/schemas/response.schema.json",
  "title": "Ausecon Retrieval Response",
  "description": "Normalised retrieval response returned by ABS, RBA, semantic, and derived data tools.",
  "type": "object",
  "required": ["metadata", "series", "observations"],
  "additionalProperties": false,
  "properties": {
    "metadata": {
      "description": "Source, provenance, cache, and retrieval metadata for this response.",
      "$ref": "#/$defs/metadata"
    },
    "series": {
      "description": "Series descriptors keyed by series_id.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/series_descriptor"
      }
    },
    "observations": {
      "description": "Long-form observations keyed by date and series_id.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/observation"
      }
    }
  },
  "$defs": {
    "metadata": {
      "type": "object",
      "required": ["source", "dataset_id", "server_version", "truncated"],
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string",
          "enum": ["abs", "rba", "derived"]
        },
        "dataset_id": {
          "type": "string"
        },
        "frequency": {
          "type": ["string", "null"]
        },
        "title": {
          "type": ["string", "null"]
        },
        "publication_date": {
          "type": ["string", "null"]
        },
        "retrieval_url": {
          "type": "string"
        },
        "retrieved_at": {
          "type": "string",
          "format": "date-time"
        },
        "server_version": {
          "type": "string"
        },
        "truncated": {
          "type": "boolean"
        },
        "updated_after": {
          "type": ["string", "null"]
        },
        "stale": {
          "type": "boolean"
        },
        "cached_at": {
          "type": "number"
        },
        "expires_at": {
          "type": "number"
        },
        "bundle": {
          "type": ["string", "array", "object", "null"]
        },
        "semantic": {
          "description": "Semantic concept provenance when returned by get_economic_series.",
          "$ref": "#/$defs/semantic_metadata"
        },
        "derived": {
          "description": "Derived-series provenance when returned by get_derived_series.",
          "$ref": "#/$defs/derived_metadata"
        }
      }
    },
    "semantic_bounds": {
      "type": "object",
      "required": ["start", "end"],
      "additionalProperties": false,
      "properties": {
        "start": {
          "type": ["string", "null"]
        },
        "end": {
          "type": ["string", "null"]
        }
      }
    },
    "semantic_target": {
      "type": "object",
      "required": ["source", "dataset_id", "upstream_id", "abs_key", "rba_series_ids"],
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string",
          "enum": ["abs", "rba"]
        },
        "dataset_id": {
          "type": "string"
        },
        "upstream_id": {
          "type": "string"
        },
        "abs_key": {
          "type": ["string", "null"]
        },
        "rba_series_ids": {
          "type": ["array", "null"],
          "items": {
            "type": "string"
          }
        }
      }
    },
    "semantic_metadata": {
      "type": "object",
      "required": [
        "concept",
        "variant",
        "geography",
        "frequency",
        "requested_bounds",
        "resolved_bounds",
        "target"
      ],
      "additionalProperties": false,
      "properties": {
        "concept": {
          "type": "string"
        },
        "variant": {
          "type": ["string", "null"]
        },
        "geography": {
          "type": ["string", "null"]
        },
        "frequency": {
          "type": ["string", "null"]
        },
        "requested_bounds": {
          "$ref": "#/$defs/semantic_bounds"
        },
        "resolved_bounds": {
          "$ref": "#/$defs/semantic_bounds"
        },
        "target": {
          "$ref": "#/$defs/semantic_target"
        }
      }
    },
    "derived_operand": {
      "type": "object",
      "required": [
        "name",
        "concept",
        "source",
        "dataset_id",
        "upstream_id",
        "abs_key",
        "rba_series_ids",
        "series_ids"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "concept": {
          "type": "string"
        },
        "source": {
          "type": ["string", "null"],
          "enum": ["abs", "rba", null]
        },
        "dataset_id": {
          "type": ["string", "null"]
        },
        "upstream_id": {
          "type": ["string", "null"]
        },
        "abs_key": {
          "type": ["string", "null"]
        },
        "rba_series_ids": {
          "type": ["array", "null"],
          "items": {
            "type": "string"
          }
        },
        "series_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "derived_dropped_observations": {
      "type": "object",
      "required": ["input", "derived", "returned", "dropped"],
      "additionalProperties": false,
      "properties": {
        "input": {
          "type": "integer",
          "minimum": 0
        },
        "derived": {
          "type": "integer",
          "minimum": 0
        },
        "returned": {
          "type": "integer",
          "minimum": 0
        },
        "dropped": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "derived_metadata": {
      "type": "object",
      "required": [
        "concept",
        "formula",
        "operands",
        "source_concepts",
        "alignment_frequency",
        "units",
        "requested_bounds",
        "resolved_bounds",
        "dropped_observations"
      ],
      "additionalProperties": false,
      "properties": {
        "concept": {
          "type": "string"
        },
        "formula": {
          "type": "string"
        },
        "operands": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/derived_operand"
          }
        },
        "source_concepts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "alignment_frequency": {
          "type": "string"
        },
        "units": {
          "type": "string"
        },
        "requested_bounds": {
          "$ref": "#/$defs/semantic_bounds"
        },
        "resolved_bounds": {
          "$ref": "#/$defs/semantic_bounds"
        },
        "dropped_observations": {
          "$ref": "#/$defs/derived_dropped_observations"
        }
      }
    },
    "dimension_value": {
      "type": "object",
      "required": ["code", "label"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string"
        },
        "label": {
          "type": "string"
        }
      }
    },
    "dimensions": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/dimension_value"
      }
    },
    "series_descriptor": {
      "type": "object",
      "required": ["series_id", "label", "dimensions"],
      "additionalProperties": false,
      "properties": {
        "series_id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "unit": {
          "type": ["string", "null"]
        },
        "frequency": {
          "type": ["string", "null"]
        },
        "dimensions": {
          "$ref": "#/$defs/dimensions"
        },
        "source_key": {
          "type": ["string", "null"]
        },
        "unit_multiplier": {
          "description": "ABS UNIT_MULT value when supplied by the source.",
          "type": ["integer", "null"]
        },
        "decimals": {
          "description": "ABS DECIMALS value when supplied by the source.",
          "type": ["integer", "null"]
        },
        "base_period": {
          "description": "ABS BASE_PERIOD value when supplied by the source.",
          "type": ["string", "null"]
        }
      }
    },
    "observation": {
      "type": "object",
      "required": ["date", "series_id", "value", "dimensions"],
      "additionalProperties": false,
      "properties": {
        "date": {
          "description": "Observation date as an ISO date or source-native ABS period.",
          "oneOf": [
            {
              "type": "string",
              "pattern": "^\\d{4}-(0[1-9]|1[0-2])-[0-3][0-9]$",
              "format": "date"
            },
            {
              "type": "string",
              "pattern": "^\\d{4}$"
            },
            {
              "type": "string",
              "pattern": "^\\d{4}-Q[1-4]$"
            },
            {
              "type": "string",
              "pattern": "^\\d{4}-(0[1-9]|1[0-2])$"
            },
            {
              "type": "string",
              "pattern": "^\\d{4}-S[1-2]$"
            }
          ]
        },
        "series_id": {
          "type": "string"
        },
        "value": {
          "type": ["number", "null"]
        },
        "raw_value": {
          "type": ["string", "null"]
        },
        "dimensions": {
          "$ref": "#/$defs/dimensions"
        },
        "status": {
          "type": ["string", "null"]
        },
        "comment": {
          "description": "ABS observation comment when supplied by the source.",
          "type": ["string", "null"]
        }
      }
    }
  }
}
